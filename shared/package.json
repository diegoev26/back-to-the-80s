{
  "name": "@project/shared",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "if exist dist rmdir /s /q dist",
    "build": "tsc && tsc-alias --resolve-full-paths",
    "dev": "npm run build && nodemon --watch src --ext ts --exec \"npm run build\""
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "tsc-alias": "^1.8.16"
  }
}
