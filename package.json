{
  "name": "back-to-the-80s",
  "description": "La mejor fiesta de los 80 de Lationoamérica",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "client",
    "serverless"
  ],
  "scripts": {
    "/* --- LIMPIEZA --- */": "",
    "clean:shared": "npm run clean -w @project/shared",
    "clean:client": "npm run clean -w client",
    "clean:serverless-worker": "npm run clean -w serverless-worker",
    "/* --- ORQUESTADORES DE LIMPIEZA --- */": "",
    "clean:ts": "npm run clean:shared && npm run clean:backend && npm run clean:client && npm run clean:serverless-worker",
    "clean:all": "npm run clean:service && npm run clean:ts",
    "/* --- DESARROLLO --- */": "",
    "dev:shared": "npm run dev -w @project/shared",
    "dev:client": "npm run dev -w client",
    "dev:serverless-worker": "npm run dev -w serverless-worker",
    "dev-remote:serverless-worker": "npm run dev:remote -w serverless-worker",
    "/* --- ORQUESTADORES DE DESARROLLO --- */": "",
    "dev:all": "npx concurrently -k -n \"BE,SH,WK,CL\" -c \"yellow,green,cyan\" \"npm run dev:shared\" \"npm run dev:serverless-worker\" \"npm run dev:client\"",
    "/* --- COMPILACIÓN --- */": "",
    "build:shared": "npm run build -w @project/shared",
    "build:client": "npm run build -w client",
    "/* --- ORQUESTADORES DE COMPILACIÓN --- */": "",
    "build:all": "npm run build:shared && npm run build:client"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diegoev26/back-to-the-80s.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/diegoev26/back-to-the-80s/issues"
  },
  "homepage": "https://github.com/diegoev26/back-to-the-80s#readme",
  "devDependencies": {
    "@types/node": "^25.9.4",
    "concurrently": "^10.0.3",
    "typescript": "^6.0.3"
  }
}
