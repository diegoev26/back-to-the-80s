{
  "name": "template",
  "private": true,
  "workspaces": [
    "@project/shared",
    "client",
    "backend"
  ],
  "scripts": {
    "dev:client": "npm run dev -w client",
    "dev:backend": "npm run dev -w backend",
    "dev:service": "dotnet watch --project service/service.csproj",
    "types": "npx openapi-typescript http://127.0.0.1:5000/swagger/v1/swagger.json -o ./shared/src/types/api-generated.ts",
    "sync:types": "node scripts/sync-types.js",
    "sync:types:once": "node scripts/sync-types.js --once",
    "dev:all": "npx concurrently -k -n \"SV,TS,BE,CL\" -c \"magenta,blue,green,cyan\" \"npm run dev:service\" \"npm run sync:types\" \"npm run dev:backend\" \"npm run dev:client\"",
    "build:shared": "tsc -p shared/tsconfig.json",
    "build:client": "npm run build -w client",
    "build:backend": "npm run build -w backend",
    "build:service": "dotnet publish -c Release -o out",
    "build:all": "npm run build:service && npm run sync:types:once && npm run build:shared && npm run build:backend && npm run build:client"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
