{
  "name": "template",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "client",
    "serverless/worker"
  ],
  "scripts": {
    "clean:shared": "npm run clean -w @project/shared",
    "clean:serverless-worker": "npm run clean -w serverless-worker",
    "clean:client": "npm run clean -w client",
    "clean:all": "npm run clean:shared && npm run clean:serverless-worker && npm run clean:client",
    "dev:shared": "npm run dev -w @project/shared",
    "dev:client": "npm run dev -w client",
    "dev:backend": "npm run dev -w backend",
    "dev:serverless-worker": "npm run dev -w serverless-worker",
    "dev-remote:serverless-worker": "npm run dev:remote -w serverless-worker",
    "dev:service": "dotnet watch --project service/service.csproj",
    "types": "npx openapi-typescript http://127.0.0.1:5000/swagger/v1/swagger.json -o ./shared/src/types/api-generated.ts",
    "sync:types": "node scripts/sync-types.js",
    "sync:types:once": "node scripts/sync-types.js --once",
    "dev:all": "npx concurrently -k -n \"SH,SL,CL\" -c \"yellow,green,cyan\" \"npm run dev:shared\" \"npm run dev:serverless-worker\" \"npm run dev:client\"",
    "build:shared": "tsc -p shared/tsconfig.json",
    "build:client": "npm run build -w client",
    "build:backend": "npm run build -w backend",
    "build:service": "dotnet publish -c Release -o out",
    "build:all": "npm run build:service && npm run sync:types:once && npm run build:shared && npm run build:backend && npm run build:client"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
